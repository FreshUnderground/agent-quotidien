# === Cursor ===
CURSOR_API_KEY=cursor_votre_cle_ici

# combined = 1 seul message (email + WhatsApp) | separate = 4 messages
NOTIFY_MODE=combined

# === Email (Gmail exemple) ===
SEND_EMAIL=true
NOTIFY_EMAIL=dieumercikamina@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dieumercikamina@gmail.com
SMTP_PASSWORD=mot_de_passe_application_16_caracteres
SMTP_FROM=dieumercikamina@gmail.com

# === WhatsApp — Option A : CallMeBot (GRATUIT, simple) ===
# 1. Ajoutez +34 644 71 83 72 dans vos contacts WhatsApp (nom : CallMeBot)
# 2. Envoyez : "I allow callmebot to send me messages"
# 3. Recevez votre API key sur WhatsApp
# 4. Site : https://www.callmebot.com/blog/free-api-whatsapp-messages/
SEND_WHATSAPP=true
WHATSAPP_PROVIDER=callmebot
WHATSAPP_PHONE=+243975955375
CALLMEBOT_APIKEY=votre_apikey_callmebot

# === Telegram CallMeBot (gratuit) ===
# @CallMeBot_txtbot → /start → puis votre pseudo
SEND_TELEGRAM=true
TELEGRAM_MODE=user
TELEGRAM_USER=@votre_pseudo_telegram
# Mode groupe (optionnel) :
# TELEGRAM_MODE=group
# TELEGRAM_GROUP_APIKEY=votre_cle_groupe

# === Génération d'images (automatique) ===
# template = pro, texte FR lisible (recommandé) | pollinations | openai
GENERATE_IMAGES=true
IMAGE_PROVIDER=template
# OPENAI_API_KEY=sk-...  (optionnel, secret GitHub)

